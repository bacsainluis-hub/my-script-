--// KainoX Local UI Library
            local UICorner = Instance.new("UICorner")
            UICorner.CornerRadius = UDim.new(0,8)
            UICorner.Parent = Button

            Button.MouseButton1Click:Connect(function()
                TweenService:Create(Button,TweenInfo.new(0.15),{
                    BackgroundColor3 = Color3.fromRGB(255,0,100)
                }):Play()

                task.wait(0.15)

                TweenService:Create(Button,TweenInfo.new(0.15),{
                    BackgroundColor3 = Color3.fromRGB(140,0,50)
                }):Play()

                if callback then
                    callback()
                end
            end)
        end

        function Tab:AddToggle(text, default, callback)
            local Enabled = default or false

            local Toggle = Instance.new("TextButton")
            Toggle.Size = UDim2.new(0,250,0,40)
            Toggle.BackgroundColor3 = Color3.fromRGB(140,0,50)
            Toggle.Text = text .. " : " .. tostring(Enabled)
            Toggle.TextColor3 = Color3.new(1,1,1)
            Toggle.Font = Enum.Font.GothamBold
            Toggle.TextSize = 18
            Toggle.Parent = Page

            local UICorner = Instance.new("UICorner")
            UICorner.CornerRadius = UDim.new(0,8)
            UICorner.Parent = Toggle

            Toggle.MouseButton1Click:Connect(function()
                Enabled = not Enabled
                Toggle.Text = text .. " : " .. tostring(Enabled)

                if callback then
                    callback(Enabled)
                end
            end)
        end

        function Tab:AddTextbox(placeholder, callback)
            local Box = Instance.new("TextBox")
            Box.Size = UDim2.new(0,250,0,40)
            Box.BackgroundColor3 = Color3.fromRGB(110,0,40)
            Box.PlaceholderText = placeholder
            Box.Text = ""
            Box.TextColor3 = Color3.new(1,1,1)
            Box.PlaceholderColor3 = Color3.fromRGB(220,220,220)
            Box.Font = Enum.Font.GothamBold
            Box.TextSize = 18
            Box.Parent = Page

            local UICorner = Instance.new("UICorner")
            UICorner.CornerRadius = UDim.new(0,8)
            UICorner.Parent = Box

            Box.FocusLost:Connect(function()
                if callback then
                    callback(Box.Text)
                end
            end)
        end

        return Tab
    end

    return Window
end

return Library
