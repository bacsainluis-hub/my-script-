local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/memejames/elerium-v2-ui-library//main/Library", true))()

--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

local Player = Players.LocalPlayer

--// UI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AntiFreezeUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = Player:WaitForChild("PlayerGui")

local Label = Instance.new("TextLabel")
Label.Size = UDim2.new(0, 180, 0, 40)
Label.Position = UDim2.new(0, 10, 0.5, -20)
Label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Label.BorderSizePixel = 0
Label.Text = "🛡 ANTI FREEZE: ON"
Label.TextColor3 = Color3.fromRGB(0, 255, 100)
Label.Font = Enum.Font.GothamBold
Label.TextSize = 14
Label.Parent = ScreenGui

--// NOTIFICATION
StarterGui:SetCore("SendNotification", {
	Title = "Anti Freeze",
	Text = "Anti Freeze Activated",
	Duration = 3
})

--// ANTI FREEZE LOGIC
RunService.Heartbeat:Connect(function()
	local Character = Player.Character
	if not Character then return end

	local Humanoid = Character:FindFirstChildOfClass("Humanoid")
	local Root = Character:FindFirstChild("HumanoidRootPart")

	if Humanoid and Root then
		-- If frozen / stuck
		if Root.Anchored or Humanoid.WalkSpeed <= 0 then
			Root.Anchored = false
			Humanoid.WalkSpeed = 16
			Humanoid.JumpPower = 50

			-- Small nudge to unfreeze
			Root.CFrame = Root.CFrame + Vector3.new(0, 2, 0)

			StarterGui:SetCore("SendNotification", {
				Title = "Anti Freeze",
				Text = "Freeze detected & removed",
				Duration = 2
			})
		end
	end
end)

