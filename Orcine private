-- [[ 2. FORMATTER FUNCTION ]]
local function FormatNumber(value)
    value = tonumber(value) or 0
    if value < 1000 then return tostring(value) end
    
    local suffixes = {"", "K", "M", "B", "T", "QA", "QI", "SX", "SP", "O", "N", "D"}
    local index = math.floor(math.log(value, 1000)) + 1
    index = math.min(index, #suffixes)
    
    local shortValue = value / (1000 ^ (index - 1))
    return string.format("%.2f%s", shortValue, suffixes[index]):gsub("%.00", "")
end

